# Exchange credentials (required only for live orders)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Safety defaults
BYBIT_TESTNET=true
DRY_RUN=true
LIVE_TRADE_CONFIRMATION=false

# Scope
SYMBOL=BTCUSDT
POLL_INTERVAL_SEC=30

# Strategy timeframes (fixed for this strategy)
SIGNAL_INTERVAL=15
TREND_INTERVAL=60
SIGNAL_CANDLE_LIMIT=300
TREND_CANDLE_LIMIT=300

# Risk and execution
LEVERAGE=5
RISK_PER_TRADE_PCT=0.015
DAILY_LOSS_LIMIT_PCT=0.04
WEEKLY_LOSS_LIMIT_PCT=0.08
MAX_CONSECUTIVE_LOSSES=3
MAX_TRADES_PER_DAY=5

# 15m indicators
SIGNAL_EMA_FAST=20
SIGNAL_EMA_SLOW=50
ATR_PERIOD=14
DONCHIAN_PERIOD=20
VOLUME_SMA_PERIOD=20
VOLUME_SPIKE_MULT=1.5

# 1h indicators
TREND_EMA_FAST=50
TREND_EMA_SLOW=200
ADX_PERIOD=14
ADX_MIN=22

# Trade management
ATR_STOP_MULT=1.8
TP1_R=1.5
TP2_R=3.0
TP1_PCT=0.30
TP2_PCT=0.30

# Local accounting
STARTING_CAPITAL_USDT=1000
DB_PATH=bot.sqlite3
BACKTEST_TRADES_CSV=backtest_trades.csv

# Optional Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO

# AI signal-quality filter
AI_FILTER_ENABLED=false
AI_MODEL_PATH=models/ai_signal_filter.json
AI_SCORE_THRESHOLD=0.55
